---
pagination:
  data: industries.all
  size: 1
  alias: industry
permalink: "{{ industry.page_url }}"
---
{%- extends "layouts/base.njk" -%}


{# ─── Front-matter computed values ─────────────────────────────────────────── #}
{%- set pageTitle = "How Much Is a " + industry.display_name + " Business Worth? (" + site.dataQuarter + " " + site.dataYear + " Data)" -%}
{%- set metaDescription = industry.industry_name + " SDE Multiple: " + industry.sde_multiple_low + "× – " + industry.sde_multiple_high + "× (" + industry.data_source + "). Calculate your specific " + industry.display_name + " business valuation using " + industry.transaction_count + "+ closed transactions. Free, no email required." -%}
{%- set canonicalPath = industry.page_url -%}

{# ─── Schema ────────────────────────────────────────────────────────────────── #}
{% block schema %}
  {% include "schema/industry.njk" %}
{% endblock %}

{# ─── Page content ──────────────────────────────────────────────────────────── #}
{% block content %}

{# ── Breadcrumb ─────────────────────────────────────────────────────────────── #}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    <li><a href="/">Home</a></li>
    <li><a href="/valuation/">Business Valuation</a></li>
    <li><a href="{{ industry.category_url }}">{{ industry.industry_category }}</a></li>
    <li aria-current="page">{{ industry.display_name }}</li>
  </ol>
</nav>

{# ── H1 + Hook ──────────────────────────────────────────────────────────────── #}
<section class="industry-hero">
  <div class="container">
    <h1>How Much Is a {{ industry.display_name }} Business Worth? ({{ site.dataQuarter }} {{ site.dataYear }} Data)</h1>
    <p class="industry-hook">{{ industry.hook }}</p>
    <p class="industry-intro">
      {{ industry.display_name }} businesses typically sell for
      <strong>{{ industry.sde_multiple_low }}× to {{ industry.sde_multiple_high }}× annual SDE</strong>
      (Seller's Discretionary Earnings), with a median of <strong>{{ industry.sde_multiple_mid }}×</strong>.
      These multiples are derived from {{ industry.transaction_count }}+ closed transactions
      reported to BizBuySell ({{ industry.data_source }}) and reflect actual sale prices  -
      not asking prices.
    </p>
  </div>
</section>

{# ── SGE Summary Block ───────────────────────────────────────────────────────── #}
<section class="sge-summary-block" aria-label="{{ industry.display_name }} valuation summary">
  <div class="container">
    <div class="sge-summary-block__inner">
      <p class="sge-fact">
        The median {{ industry.display_name }} SDE multiple is <strong>{{ industry.sde_multiple_mid }}×</strong>.
      </p>
      <p class="sge-authority">
        Based on {{ industry.transaction_count }}+ closed transactions reported to BizBuySell through {{ industry.data_source }}.
      </p>
      <p class="sge-range">
        Valuations range from <strong>{{ industry.sde_multiple_low }}×</strong> to
        <strong>{{ industry.sde_multiple_high }}×</strong> depending on {{ industry.deal_notes | truncate(120, true, "…") }}
      </p>
      <dl class="sge-summary-block__stats">
        <div>
          <dt>Typical SDE Multiple</dt>
          <dd>{{ industry.sde_multiple_low }}× – {{ industry.sde_multiple_high }}×</dd>
        </div>
        <div>
          <dt>Median Multiple</dt>
          <dd>{{ industry.sde_multiple_mid }}×</dd>
        </div>
        <div>
          <dt>Revenue Multiple (avg)</dt>
          <dd>{{ industry.revenue_multiple_avg }}×</dd>
        </div>
        <div>
          <dt>Based on</dt>
          <dd>{{ industry.transaction_count }}+ transactions · {{ industry.data_source }}</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

{# ── Micro-Calculator ────────────────────────────────────────────────────────── #}
<section class="micro-calc-section">
  <div class="container">
    <p class="micro-calc-hook">
      Enter your SDE and annual revenue to see where your {{ industry.display_name }}
      business falls within the {{ site.dataYear }} transaction range.
    </p>

    <div id="micro-calc"
         class="micro-calc"
         data-slug="{{ industry.industry_slug }}"
         data-multi-low="{{ industry.sde_multiple_low }}"
         data-multi-mid="{{ industry.sde_multiple_mid }}"
         data-multi-high="{{ industry.sde_multiple_high }}"
         data-txn-count="{{ industry.transaction_count }}"
         data-ind-name="{{ industry.industry_name }}">

      {# SDE Field #}
      <div class="form-group">
        <label for="mc-sde">
          Your Annual SDE
          <button id="mc-sde-toggle" class="expander-toggle" type="button" aria-expanded="false">
            ▾ What is SDE?
          </button>
        </label>
        <div id="mc-sde-content" class="expander-content" aria-hidden="true">
          <p>
            <strong>What is SDE?</strong><br>
            SDE is your business's true earning power for a new owner. It equals:<br>
            <strong>Net profit + your salary + personal benefits run through the business + any one-time expenses</strong><br>
            Example: If your business showed $40,000 net profit, you paid yourself $90,000, and ran $15,000 in
            personal expenses through the business, your SDE is $145,000.<br>
            If you're unsure, use your best estimate - you can refine it later.
          </p>
        </div>
        <input type="text"
               id="mc-sde"
               class="input-currency"
               inputmode="numeric"
               placeholder="$0"
               autocomplete="off"
               aria-describedby="mc-sde-error">
        <span id="mc-sde-error" class="field-error" role="alert" aria-live="polite"></span>
      </div>

      {# Revenue Field #}
      <div class="form-group">
        <label for="mc-revenue">Your Annual Revenue</label>
        <input type="text"
               id="mc-revenue"
               class="input-currency"
               inputmode="numeric"
               placeholder="$0"
               autocomplete="off"
               aria-describedby="mc-rev-error">
        <span id="mc-rev-error" class="field-error" role="alert" aria-live="polite"></span>
      </div>

      <button id="mc-btn" class="btn btn--primary" type="button">
        Get My Estimate
      </button>

      {# Result (populated by micro-calc.js) #}
      <div id="mc-result" class="micro-result" aria-live="polite" aria-atomic="true"></div>

    </div>{# /micro-calc #}
  </div>
</section>

{# ── Ad Unit 1 (appears after result) ───────────────────────────────────────── #}
<div class="ad-unit ad-unit--post-result" aria-label="Advertisement">
  <div class="ad-unit__inner">
    <!-- AdSense Unit 1 - responsive display - min-height reserved for CLS -->
    <ins class="adsbygoogle"
         style="display:block;min-height:280px;"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
         data-ad-slot="XXXXXXXXXX"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
</div>

{# ── Next Steps Module ───────────────────────────────────────────────────────── #}
<section class="next-steps">
  <div class="container">
    <h2 class="next-steps__heading">What to do with this number:</h2>
    <ol class="next-steps__list">
      <li>
        <strong>Get a formal valuation</strong><br>
        A certified business appraiser or experienced broker can provide a formal opinion of value
        for sale, financing, or legal purposes.
        <a href="/guides/working-with-business-broker/">Working with a Business Broker: What to Expect →</a>
      </li>
      <li>
        <strong>Understand your deal-readiness</strong><br>
        Most businesses need 12–24 months of preparation to sell at maximum value.
        <a href="/guides/how-to-prepare-business-for-sale/">How to Prepare Your Business for Sale →</a>
      </li>
      <li>
        <strong>Review your financials</strong><br>
        Buyers and their lenders will scrutinize 3 years of tax returns and P&amp;Ls.
        <a href="/guides/preparing-financials-for-sale/">Preparing Financials for a Business Sale →</a>
      </li>
    </ol>
  </div>
</section>

{# ── Ad Unit 2 ───────────────────────────────────────────────────────────────── #}
<div class="ad-unit ad-unit--post-next-steps" aria-label="Advertisement">
  <div class="ad-unit__inner">
    <ins class="adsbygoogle"
         style="display:block;min-height:100px;"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
         data-ad-slot="XXXXXXXXXX"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
</div>

{# ── Multiple Data Table ─────────────────────────────────────────────────────── #}
<section class="industry-data">
  <div class="container">
    <h2>{{ industry.display_name }} Business Valuation Multiples ({{ site.dataQuarter }} {{ site.dataYear }})</h2>

    <div class="data-table-wrap">
      <table class="data-table">
        <caption class="sr-only">{{ industry.display_name }} SDE and revenue multiples from BizBuySell closed transaction data</caption>
        <tbody>
          <tr>
            <th scope="row">SDE Multiple (Lower Quartile)</th>
            <td>{{ industry.sde_multiple_low }}×</td>
          </tr>
          <tr>
            <th scope="row">SDE Multiple (Median)</th>
            <td>{{ industry.sde_multiple_mid }}×</td>
          </tr>
          <tr>
            <th scope="row">SDE Multiple (Upper Quartile)</th>
            <td>{{ industry.sde_multiple_high }}×</td>
          </tr>
          <tr>
            <th scope="row">Revenue Multiple (Average)</th>
            <td>{{ industry.revenue_multiple_avg }}×</td>
          </tr>
          <tr>
            <th scope="row">Transactions Analyzed</th>
            <td>{{ industry.transaction_count }}+</td>
          </tr>
          <tr>
            <th scope="row">Data Source</th>
            <td>{{ industry.data_source }}</td>
          </tr>
          <tr>
            <th scope="row">Data Coverage</th>
            <td>Q1 {{ site.dataCoverageStart }} – Q4 {{ site.dataCoverageEnd }}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p class="data-table-interp">
      A {{ industry.display_name }} business with $200,000 SDE would be valued between
      <strong>{{ industry.example_low | usd }}</strong> and
      <strong>{{ industry.example_high | usd }}</strong>
      under typical market conditions ({{ industry.sde_multiple_low }}× – {{ industry.sde_multiple_high }}× applied to $200,000 SDE).
      Your business may fall higher or lower depending on growth trend, owner involvement,
      and customer concentration - <a href="/">use the calculator</a> for an adjusted estimate.
    </p>

    {# ── How This Valuation Was Calculated (toggleable) ─────────────────────── #}
    <div class="logic-transparency">
      <button class="logic-transparency__toggle" type="button" aria-expanded="false" aria-controls="logic-transparency-body">
        <span class="logic-transparency__toggle-label">How this valuation was calculated</span>
        <span class="chevron" aria-hidden="true">▾</span>
      </button>
      <div id="logic-transparency-body" class="logic-transparency__body" hidden>
        <p>{{ industry.logic_transparency_opener }}</p>
        <p>
          The {{ industry.sde_multiple_mid }}× median multiple for {{ industry.display_name }} businesses
          is derived from {{ industry.transaction_count }}+ closed transactions reported to BizBuySell
          from Q1 {{ site.dataCoverageStart }} through Q4 {{ site.dataCoverageEnd }}.
        </p>
        <p>
          The <a href="/">full calculator</a> adjusts from the median based on revenue trend (±0.15 to 0.30×),
          owner involvement (±0.20×), and customer concentration (±0.10 to 0.25×). Strong growth plus low
          owner dependency plus diversified customers approaches the upper quartile; the inverse pushes toward
          the lower.
        </p>
        <p>
          Results are floored at 1.0× SDE - businesses rarely sell below annual earnings regardless of risk factors.
        </p>
        <p class="logic-disclaimer">
          This is a planning estimate based on closed transaction data, not a formal business appraisal.
          <a href="/methodology/">See our full methodology →</a>
        </p>
      </div>
    </div>

  </div>
</section>

{# ── What Drives Value Up ─────────────────────────────────────────────────────── #}
<section class="value-drivers">
  <div class="container">
    <h2>What Makes a {{ industry.display_name }} Business Worth More</h2>
    <p>{{ industry.deal_notes }}</p>
    <ul class="value-drivers__list">
      {% for factor in industry.what_increases_value %}
        <li>{{ factor }}</li>
      {% endfor %}
    </ul>
    <p>
      Improving these factors before going to market can meaningfully shift your multiple.
      <a href="/guides/how-to-increase-business-value/">How to Increase Your Business's Sale Price →</a>
    </p>
  </div>
</section>

{# ── What Reduces Value ──────────────────────────────────────────────────────── #}
<section class="value-reducers">
  <div class="container">
    <h2>What Can Reduce a {{ industry.display_name }} Business's Sale Price</h2>
    <p>
      Buyers and their lenders scrutinize the following risk factors when underwriting a
      {{ industry.display_name }} acquisition. Each one can reduce the multiple, extend the
      time to close, or trigger a retrade after diligence.
    </p>
    <ul class="value-reducers__list">
      {% for factor in industry.what_reduces_value %}
        <li>{{ factor }}</li>
      {% endfor %}
    </ul>
    <p>
      Understanding your risks before you list gives you time to address them.
      <a href="/guides/how-to-prepare-business-for-sale/">How to Prepare Your Business for Sale →</a>
    </p>
  </div>
</section>

{# ── Market Context ───────────────────────────────────────────────────────────── #}
<section class="market-context">
  <div class="container">
    <h2>{{ site.dataQuarter }} {{ site.dataYear }} {{ industry.display_name }} Business Sale Market</h2>

    {# Required element 1: Comparison Table (from related_industries) #}
    <div class="comparison-table-wrap">
      <table class="data-table comparison-table">
        <caption>{{ industry.display_name }} vs. related business types - SDE multiple comparison</caption>
        <thead>
          <tr>
            <th scope="col">Business Type</th>
            <th scope="col">Median SDE Multiple</th>
            <th scope="col">Primary Value Driver</th>
          </tr>
        </thead>
        <tbody>
          <tr class="comparison-table__this-row">
            <td><strong>{{ industry.display_name }}</strong> <span class="this-page-badge">this page</span></td>
            <td>{{ industry.sde_multiple_mid }}×</td>
            <td>{{ industry.deal_notes | truncate(80, true, "…") }}</td>
          </tr>
          {% for relSlug in industry.related_industries %}
            {%- set rel = industries.bySlug[relSlug] -%}
            {% if rel %}
            <tr>
              <td><a href="{{ rel.page_url }}">{{ rel.industry_name }}</a></td>
              <td>{{ rel.sde_multiple_mid }}×</td>
              <td>{{ rel.deal_notes | truncate(80, true, "…") }}</td>
            </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>

    {# Required element 2: Market Sentiment Paragraph #}
    <div class="market-sentiment">
      <p>{{ industry.market_sentiment }}</p>
    </div>

  </div>
</section>

{# ── Who Buys These Businesses ───────────────────────────────────────────────── #}
<section class="buyer-profile">
  <div class="container">
    <h2>Who Buys {{ industry.display_name }} Businesses?</h2>
    <p>{{ industry.typical_buyer_profile }}</p>
    <p>
      Understanding who your likely buyer is shapes how you prepare your financials and position
      the business. <a href="/guides/what-buyers-look-for/">What Business Buyers Look For →</a>
    </p>
  </div>
</section>

{# ── FAQ ─────────────────────────────────────────────────────────────────────── #}
<section class="industry-faq">
  <div class="container">
    <h2>Frequently Asked Questions: Selling a {{ industry.display_name }} Business</h2>

    <div class="faq-list">

      <div class="faq-item">
        <h3>What SDE multiple do {{ industry.display_name }} businesses sell for?</h3>
        <p>
          Based on {{ industry.transaction_count }}+ closed transactions reported to BizBuySell
          ({{ industry.data_source }}), {{ industry.display_name }} businesses typically sell for
          <strong>{{ industry.sde_multiple_low }}× to {{ industry.sde_multiple_high }}× annual SDE</strong>,
          with a median of {{ industry.sde_multiple_mid }}×. The range reflects the degree of owner
          involvement, revenue growth trend, and customer concentration in the specific business.
          A business with $200,000 SDE at the median multiple would be valued around
          {{ (industry.sde_multiple_mid * 200000) | round(-3) | usd }}.
        </p>
      </div>

      <div class="faq-item">
        <h3>How do I calculate the value of my {{ industry.display_name }} business?</h3>
        <p>
          The standard method for valuing a {{ industry.display_name }} business is to multiply
          your annual SDE (Seller's Discretionary Earnings) by the industry-specific multiple.
          Enter your SDE and annual revenue in the estimate tool above to see where your business
          falls within the {{ site.dataYear }} transaction range. For an estimate that accounts for
          revenue trend, owner involvement, and customer concentration, use the
          <a href="/">full valuation calculator</a> - it adjusts from the median multiple based
          on your specific conditions and typically shifts results by 20–40%.
        </p>
      </div>

      <div class="faq-item">
        <h3>What is SDE and why is it used for {{ industry.display_name }} valuations?</h3>
        <p>
          SDE - Seller's Discretionary Earnings - represents the total financial benefit a full-time
          owner-operator extracts from the business annually: net profit plus the owner's salary plus
          any personal expenses run through the business plus non-cash charges like depreciation.
          For {{ industry.display_name }} businesses under approximately $5M in revenue, SDE is the
          standard valuation basis because it normalizes for differences in how owners pay themselves.
          <a href="/guides/what-is-sde/">Full SDE explanation and calculation guide →</a>
        </p>
      </div>

      <div class="faq-item">
        <h3>How does owner involvement affect a {{ industry.display_name }} sale price?</h3>
        <p>
          Owner involvement is one of the most significant discount factors in any {{ industry.display_name }}
          acquisition. A business where the owner is central to daily operations - managing key customer
          relationships, holding specialized licenses, or performing core service delivery - faces buyers
          who discount for key-person risk. The full calculator applies a ±0.20× adjustment for owner
          involvement, which on a $300,000 SDE business equals a $60,000 swing in valuation. Businesses
          that run systems rather than rely on the owner command the upper quartile of the multiple range.
        </p>
      </div>

      <div class="faq-item">
        <h3>What financing do buyers use for {{ industry.display_name }} acquisitions?</h3>
        <p>
          {{ industry.typical_buyer_profile }} SBA 7(a) loans are the most common financing vehicle
          for Main Street acquisitions, covering up to 90% of the purchase price for qualifying transactions.
          Buyers typically require 10–20% as a down payment and 3 years of business tax returns.
          <a href="/guides/sba-acquisition-loans/">SBA Loans for Business Acquisitions: What Sellers Need to Know →</a>
        </p>
      </div>

    </div>
  </div>
</section>

{# ── Related Industries ───────────────────────────────────────────────────────── #}
<section class="related-industries">
  <div class="container">
    <h3>See also:</h3>
    <ul class="related-industries__list">
      {% for relSlug in industry.related_industries %}
        {%- set rel = industries.bySlug[relSlug] -%}
        {% if rel %}
          <li>
            <a href="{{ rel.page_url }}">
              {{ rel.industry_name }} valuation data ({{ rel.sde_multiple_low }}× – {{ rel.sde_multiple_high }}× SDE)
            </a>
          </li>
        {% endif %}
      {% endfor %}
      <li>
        <a href="{{ industry.category_url }}">
          All {{ industry.industry_category }} business valuations →
        </a>
      </li>
    </ul>
  </div>
</section>

{# ── BizBuySell Citation ──────────────────────────────────────────────────────── #}
<aside class="data-citation">
  <div class="container">
    <p>
      Transaction data: <a href="{{ site.bizBuySellUrl }}" target="_blank" rel="noopener">BizBuySell Industry Valuation Report</a>,
      {{ industry.data_source }}. Covering {{ industry.transaction_count }}+ closed transactions in the
      {{ industry.industry_category }} category. This tool provides planning estimates only and does not
      constitute a formal business appraisal.
    </p>
  </div>
</aside>

{% endblock %}

{# ─── Scripts ────────────────────────────────────────────────────────────────── #}
{% block scripts %}
<script>
  // Logic transparency toggle
  (function () {
    var btn  = document.querySelector('.logic-transparency__toggle');
    var body = document.getElementById('logic-transparency-body');
    if (!btn || !body) return;
    btn.addEventListener('click', function () {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      btn.querySelector('.chevron').style.transform = expanded ? '' : 'rotate(180deg)';
      body.hidden = expanded;
    });
  })();
</script>
<script src="/assets/js/micro-calc.js" defer></script>
{% endblock %}
